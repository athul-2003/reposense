# RepoSense — copy this file to .env and edit what you need.
# cp .env.example .env
#
# Everything here is optional. RepoSense works out of the box with just
# a GitHub PAT (set via: coral source add --interactive github).

# ── Default repo (used when --repo flag is omitted) ────────────────────────
# GITHUB_OWNER=withcoral
# GITHUB_REPO=coral

# ── Hacker News search term ─────────────────────────────────────────────────
# Auto-detected from repo topics. Override when the repo name is too generic.
# HN_QUERY=MCP server

# ── CVE scan package ────────────────────────────────────────────────────────
# Auto-detected from requirements.txt / package.json / Cargo.toml / go.mod.
# Set manually to scan a specific package at a specific version.
# Ecosystems: PyPI · npm · Go · crates.io · RubyGems · Maven · NuGet
# PACKAGE_NAME=django
# PACKAGE_ECOSYSTEM=PyPI
# PACKAGE_VERSION=4.2.0

# ── LLM for agent mode (plain English questions) ─────────────────────────────
# Set one key. Priority: Claude > Groq (free) > GPT-4o-mini.
# All 11 commands work without any key — only free-form questions need one.
# ANTHROPIC_API_KEY=sk-ant-...       # https://console.anthropic.com
# GROQ_API_KEY=gsk_...               # https://console.groq.com  (free tier)
# OPENAI_API_KEY=sk-...              # https://platform.openai.com
#
# Optional: override the default model per provider
# ANTHROPIC_MODEL=claude-sonnet-4-6         # or claude-opus-4-7 / claude-haiku-4-5-20251001
# OPENAI_MODEL=gpt-4o-mini                  # or gpt-4o (default: gpt-4o-mini — 17x cheaper)
# GROQ_MODEL=llama-3.3-70b-versatile        # any model available on console.groq.com

# ── Stack Overflow source ────────────────────────────────────────────────────
# Install: coral source add --file sources/stackoverflow/manifest.yaml
# Works without a key (300 req/day free). Key raises limit to 10,000/day.
# STACK_EXCHANGE_KEY=...             # https://stackapps.com → Register App
